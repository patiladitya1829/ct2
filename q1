#include <stdio.h>
// Write a C program that will accept 5 data elements in array and arrange
// them in ascending order.
int main() 
{
   int arr[5] ,i , j , temp;
    printf("Enter 5 numbers: ");
    for(i=0;i<5;i++)
    {
        scanf("%d",&arr[i]);
    }
    for(i=0;i<5;i++)
    {
        for(j=i+1;j<5;j++)
        {
            if(arr[i]>arr[j])
            {
            temp=arr[i];
            arr[i]=arr[j];
            arr[j]=temp;
            }
            // printf(" array element in asending order is %d\n",arr[i]);
        }
        printf(" array element in asending order is %d\n",arr[i]);
        
    }
    return 0;
}
